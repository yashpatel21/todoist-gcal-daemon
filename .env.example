# =============================================================================
# Secrets (required for Docker Compose, Portainer, and local `npm start`)
# =============================================================================
TODOIST_API_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# =============================================================================
# Optional: local `npm start` / `npm run dev` only
# =============================================================================
# When running with Node on your machine, you can tune these. The Docker
# Compose file hardcodes non-secrets instead; see docker-compose.yml.
#
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8765/oauth/callback
# POLL_INTERVAL_SECONDS=60
# DATABASE_PATH=./data/sync.db
# MANAGED_CALENDAR_PREFIX=Todoist: 
# SPECIAL_CALENDAR_REMINDERS=Reminders
# SPECIAL_CALENDAR_TASKS=Tasks
# LOG_LEVEL=info
